/**
 * RocketGame: מנהל את הלוגיקה של המשחק, זיהוי מקשים ותנועת הטיל.
 */
class RocketGame {
   field Rocket rocket; // האובייקט של הטיל
   field int direction; // כיוון התנועה: 0=עצור, 1=למעלה, 2=למטה, 3=שמאלה, 4=ימינה

   /** בונה משחק חדש וממקם את הטיל במרכז המסך */
   constructor RocketGame new() {
      // יצירת הטיל במיקום התחלתי (למשל x=240, y=120)
      let rocket = Rocket.new(240, 120);
      let direction = 0; // בהתחלה הטיל לא זז
      return this;
   }

   /** משחרר את הזיכרון של המשחק */
   method void dispose() {
      do rocket.dispose();
      do Memory.deAlloc(this);
      return;
   }

   /** מזיז את הטיל לפי הכיוון שנבחר */
   method void moveRocket() {
      if (direction = 1) { do rocket.moveUp(); }
      if (direction = 2) { do rocket.moveDown(); }
      if (direction = 3) { do rocket.moveLeft(); }
      if (direction = 4) { do rocket.moveRight(); }
      do Sys.wait(5); // השהייה קלה כדי שהתנועה לא תהיה מהירה מדי
      return;
   }

   /** מריץ את המשחק ומטפל בקלט מהמשתמש */
   method void run() {
      var char key;  // המקש שנלחץ
      var boolean exit;
      let exit = false;
      
      while (~exit) {
         // לולאה שמחכה ללחיצה על מקש
         while (key = 0) {
            let key = Keyboard.keyPressed();
            do moveRocket();
         }

         if (key = 81)  { let exit = true; }     // מקש 'q' ליציאה
         if (key = 90)  { do rocket.decSize(); } // מקש 'z' להקטנה
         if (key = 88)  { do rocket.incSize(); } // מקש 'x' להגדלה
         if (key = 131) { let direction = 1; }   // חץ למעלה
         if (key = 133) { let direction = 2; }   // חץ למטה
         if (key = 130) { let direction = 3; }   // חץ שמאלה
         if (key = 132) { let direction = 4; }   // חץ ימינה

         // לולאה שמחכה שהמשתמש ישחרר את המקש
         while (~(key = 0)) {
            let key = Keyboard.keyPressed();
            do moveRocket();
         }
      }
      return;
   }

   /** מחזיר את כמות הפעולות הסופית לצורך הדפסה ב-Main */
   method int getFinalCount() {
      return rocket.getCount(); // מחזיר את ה-count שנשמר בתוך האובייקט של הטיל
   }
}